function recreate_pellets() {
	global.pellet_total = 0;
	global.pellet_count = 0;
	
	var maze = [
		"############################",
		"#............##............#",
		"#.####.#####.##.#####.####.#",
		"#o####.#####.##.#####.####o#",
		"#.####.#####.##.#####.####.#",
		"#..........................#",
		"#.####.##.########.##.####.#",
		"#.####.##.########.##.####.#",
		"#......##....##....##......#",
		"######.#####.##.#####.######",
		"     #.#####.##.#####.#     ",
		"     #.##          ##.#     ",
		"     #.## ###--### ##.#     ",
		"######.## #      # ##.######",
		"      .   #      #   .      ",
		"######.## #      # ##.######",
		"     #.## ######## ##.#     ",
		"     #.##          ##.#     ",
		"     #.##          ##.#     ",
		"######.## ######## ##.######",
		"#............##............#",
		"#.####.#####.##.#####.####.#",
		"#.####.#####.##.#####.####.#",
		"#o..##.......  .......##..o#",
		"###.##.##.########.##.##.###",
		"###.##.##.########.##.##.###",
		"#......##....##....##......#",
		"#.##########.##.##########.#",
		"#.##########.##.##########.#",
		"#..........................#",
		"############################"
	];

	var tile = 8;
	var offset_y = 28;
	var offset_x = 4;

	for (var y_ = 0; y_ < array_length(maze); y_++)
	{
	    var row = maze[y_];

	    for (var x_ = 0; x_ < string_length(row); x_++)
	    {
	        var c = string_char_at(row, x_ + 1);

	        var px = offset_x + x_ * tile;
	        var py = offset_y + y_ * tile;

	        switch (c)
	        {
	            case "#":
	                break;

	            case ".":
					global.pellet_total++;
	                instance_create_depth(px, py, -1, obj_pellet);
	                break;

	            case "o":
					global.pellet_total++;
	                instance_create_depth(px, py, -1, obj_power_pellet);
	                break;
	        }
	    }
	}
}